{
  "name": "vibedevview",
  "version": "0.1.0",
  "description": "HGDW multi-agent video production system (orchestrator + script/slides/voice/recording agents) that assembles educational videos onto a Palmier Pro timeline, with an ffmpeg preview backend for machines without Palmier.",
  "type": "module",
  "bin": {
    "palmier": "./dist/cli.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./types": "./dist/types.js",
    "./events": "./dist/events.js",
    "./script/parse": "./dist/script/parse.js",
    "./slides/deck": "./dist/slides/deck-template.js"
  },
  "files": [
    "dist",
    "assets"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "palmier": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "commander": "^12.1.0",
    "playwright": "^1.49.1",
    "yaml": "^2.6.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
