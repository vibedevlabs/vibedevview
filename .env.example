# ── HGDW Palmier — environment ──────────────────────────────────────────────
# Copy to `.env` and fill in. Never commit `.env`.

# ElevenLabs (Voice Agent). Required for real TTS; without it the Voice Agent
# falls back to silent placeholders so the rest of the pipeline still runs.
ELEVENLABS_API_KEY=

# Override the voice for a run (name or raw ElevenLabs id). Defaults to the
# script's `voice:` frontmatter (the examples use Ja'dan).
# PALMIER_VOICE=Ja'dan

# Mux (publish step — optional). Used by `palmier publish`.
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=

# LLM for the Script Agent (optional). If unset, the Script Agent only works
# from an existing script.md / topic-brief.md you provide.
#   provider: anthropic | openai | moonshot | deepseek
PALMIER_LLM_PROVIDER=anthropic
PALMIER_LLM_API_KEY=
PALMIER_LLM_MODEL=claude-3-7-sonnet-latest

# Slide renderer.
#   PALMIER_RENDERER=launch  → Playwright launches its own Chromium (default; works on macOS/CI)
#   PALMIER_RENDERER=cdp     → connect to an already-running Chrome over CDP
PALMIER_RENDERER=launch
# When PALMIER_RENDERER=cdp, the DevTools endpoint to attach to:
PALMIER_CDP_URL=http://localhost:29229
# Optional explicit Chrome/Chromium executable for launch mode:
# PALMIER_CHROME_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome

# Timeline backend.
#   PALMIER_TIMELINE=palmier → drive Palmier Pro over MCP (macOS, app open)
#   PALMIER_TIMELINE=ffmpeg  → assemble a preview MP4 locally (portable / cloud)
PALMIER_TIMELINE=ffmpeg
PALMIER_MCP_URL=http://127.0.0.1:19789/mcp

# Where productions live. Defaults to ~/hgdw-productions
# PALMIER_PRODUCTIONS_DIR=/Users/you/hgdw-productions
